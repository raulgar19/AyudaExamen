@model ComicImageSimpleModel

@{
    int primero = 1;
    int anterior = (int)ViewData["ANTERIOR"];
    int siguiente = (int)ViewData["SIGUIENTE"];
    int ultimo = (int)ViewData["ULTIMO"];
    int posicion = (int)ViewData["POSICION"];
}

<h1>Detalles de @Model.Comic.Name</h1>

<ul class="list-group">
    <li class="list-group-item"><strong>Id:</strong> @Model.Comic.Id</li>
    <li class="list-group-item"><strong>Title:</strong> @Model.Comic.Name</li>
    <li class="list-group-item"><strong>Author:</strong> @Model.Comic.Author</li>
    <li class="list-group-item"><strong>Year:</strong> @Model.Comic.Year</li>
</ul>

<hr />
<h3>Imagen @posicion de @ultimo</h3>
<ul class="list-group list-group-horizontal mb-3">
    <li class="list-group-item">
        <a asp-controller="Comics"
           asp-action="DetailsSimple"
           asp-route-posicion="@primero"
           asp-route-id="@Model.Comic.Id">Primero</a>
    </li>
    <li class="list-group-item">
        <a asp-controller="Comics"
           asp-action="DetailsSimple"
           asp-route-posicion="@anterior"
           asp-route-id="@Model.Comic.Id">Anterior</a>
    </li>
    <li class="list-group-item">
        <a asp-controller="Comics"
           asp-action="DetailsSimple"
           asp-route-posicion="@siguiente"
           asp-route-id="@Model.Comic.Id">Siguiente</a>
    </li>
    <li class="list-group-item">
        <a asp-controller="Comics"
           asp-action="DetailsSimple"
           asp-route-posicion="@ultimo"
           asp-route-id="@Model.Comic.Id">Último</a>
    </li>
</ul>
<hr />
@if (Model.Imagen != null)
{
    <img src="@Model.Imagen.Url" style="width: 400px; height:auto;" />
}
else
{
    <p>No hay imagen disponible para esta posición.</p>
}
