@model List<Comic>

<h1>Comics</h1>

<table class="table table-warning">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Year</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (Comic comic in Model)
        {
            <tr>
                <td>@comic.Name</td>
                <td>@comic.Author</td>
                <td>@comic.Year</td>
                <td>
                    <a asp-controller="Comics" asp-action="DetailsSimple" asp-route-id="@comic.Id" class="btn btn-info">Details Simple</a>
                    <a asp-controller="Comics" asp-action="DetailsComplejo" asp-route-id="@comic.Id" class="btn btn-info">Details Complejo</a>
                    <a asp-controller="Comics" asp-action="AddToCarritoSesion" asp-route-id="@comic.Id" class="btn btn-info">Add to Carrito</a>
                </td>
            </tr>
        }
    </tbody>
</table>